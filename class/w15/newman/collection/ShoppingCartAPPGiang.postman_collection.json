                      "// 4. Validera innehållet i listan",
                      "if (response.length > 0) {",
                      "    pm.test(\"Första produkten har rätt fält\", function () {",
                      "        const firstItem = response[0];",
                      "        pm.expect(firstItem).to.have.property('id');",
                      "        pm.expect(firstItem).to.have.property('name');",
                      "    });",
                      "}",
                      "",
                      "// 5. LOGISK KONTROLL: Finns vår nyss skapade produkt i listan?",
                      "const lastId = pm.environment.get(\"last_product_id\");",
                      "if (lastId) {",
                      "    pm.test(`Produkt med ID ${lastId} finns i listan`, function () {",
                      "        const found = response.find(p => p.id == lastId);",
                      "        pm.expect(found).to.not.be.undefined;",
