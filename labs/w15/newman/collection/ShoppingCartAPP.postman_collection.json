    {
      "name": "Products",
      "item": [
        {
          "name": "Admin adds product to the catalog",
          "item": [
            {
              "name": "Create Product",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "let token = pm.collectionVariables.get(\"token\");\r",
                      "let productName = \"Apple_\" + Date.now();\r",
                      "pm.collectionVariables.set(\"productName\", productName);\r",
                      "\r",
                      "pm.request.headers.upsert({\r",
                      "    key: \"Authorization\",\r",
                      "    value: \"Bearer \" + token\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "let jsonData = pm.response.json();\r",
                      "let expectedName = pm.collectionVariables.get(\"productName\");\r",
                      "\r",
                      "pm.test(\"Status is 200 or 201\", function () {\r",
                      "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Product created with correct name\", function () {\r",
                      "    pm.expect(jsonData.name).to.eql(expectedName);\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Product has id\", function () {\r",
                      "    pm.expect(jsonData.id).to.not.be.undefined;\r",
                      "});\r",
                      "\r",
                      "pm.collectionVariables.set(\"productId\", jsonData.id);\r",
                      "console.log(\"Saved productId:\", jsonData.id);"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\r\n  \"name\": \"{{productName}}\"\r\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "{{app_url}}/product",
                  "host": [
                    "{{app_url}}"
                  ],
                  "path": [
                    "product"
                  ]
                }
              },
              "response": []
            }
          ],
          "description": "Given I am an admin user​\n\nWhen I add a product to the catalog​\n\nThen The product is available to be used in the app"
        },
        {
          "name": "Admin removes product from the catalog",
          "item": [
            {
              "name": "Delete Product",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "let token = pm.collectionVariables.get(\"token\");\r",
                      "let productId = pm.collectionVariables.get(\"productId\");\r",
                      "\r",
                      "console.log(\"token:\", token);\r",
                      "console.log(\"productId:\", productId);\r",
                      "\r",
                      "pm.request.headers.upsert({\r",
                      "    key: \"Authorization\",\r",
                      "    value: \"Bearer \" + token\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "let jsonData = pm.response.json();\r",
                      "\r",
                      "pm.test(\"Status is 200\", function () {\r",
                      "    pm.response.to.have.status(200);\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Deleted correct product\", function () {\r",
                      "    pm.expect(jsonData.id).to.eql(parseInt(pm.collectionVariables.get(\"productId\")));\r",
                      "    pm.expect(jsonData.name).to.eql(pm.collectionVariables.get(\"productName\"));\r",
                      "});\r",
                      "\r",
                      "pm.collectionVariables.unset(\"productId\");\r",
                      "pm.collectionVariables.unset(\"productName\");"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "DELETE",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "{{app_url}}/product/{{productId}}",
                  "host": [
                    "{{app_url}}"
                  ],
                  "path": [
                    "product",
                    "{{productId}}"
                  ]
                }
              },
              "response": []
            }
          ],
          "description": "Given I am an admin user​\n\nWhen I remove a product from the catalog​\n\nThen The product should not be listed in the app to be used"
        }
