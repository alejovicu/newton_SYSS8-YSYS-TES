                      "    pm.expect(json.id).to.be.above(0);",
                      "});",
                      "",
                      "pm.test(\"Product name matches the request\", function () {",
                      "    const sentName = pm.collectionVariables.get(\"random_product_name\");",
                      "    pm.expect(json.name).to.eql(sentName);",
