  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create new customer",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function generateRandomString(length) {",
                  "    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';",
                  "    let result = '';",
                  "    for (let i = 0; i < length; i++) {",
                  "        result += chars.charAt(Math.floor(Math.random() * chars.length));",
                  "        }",
                  "        return result;",
                  "}",
                  "",
                  "const newCustomer = \"customer_\" + generateRandomString(20);",
                  "",
                  "pm.collectionVariables.set(\"newCustomer\", newCustomer);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const expectedUsername = pm.collectionVariables.get(\"newCustomer\")",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Username is correct\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.username).to.eql(expectedUsername);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"{{newCustomer}}\",\n    \"password\": \"1234\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{app_url}}/signup",
              "host": [
                "{{app_url}}"
              ],
              "path": [
                "signup"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login as new customer",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const adminUsername = pm.environment.get(\"admin_username\");",
                  "const adminPassword = pm.environment.get(\"admin_password\");",
                  "",
                  "if (adminUsername && adminPassword) {",
                  "    pm.variables.set(\"login_username_effective\", adminUsername);",
                  "    pm.variables.set(\"login_password_effective\", adminPassword);",
                  "} else {",
                  "    pm.variables.set(\"login_username_effective\", pm.collectionVariables.get(\"newCustomer\"));",
                  "    pm.variables.set(\"login_password_effective\", \"1234\");",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let json;",
                  "try {",
                  "    json = pm.response.json();",
                  "} catch (e) {",
                  "    json = {};",
                  "}",
                  "",
                  "const rawToken =",
                  "    json.access_token ??",
                  "    json.token ??",
                  "    json.data?.access_token ??",
                  "    json.data?.token ??",
                  "    json.result?.access_token ??",
                  "    json.result?.token;",
                  "",
                  "const tokenType =",
                  "    json.token_type ??",
                  "    json.data?.token_type ??",
                  "    json.result?.token_type ??",
                  "    'Bearer';",
                  "",
                  "pm.test(\"Access token is present in the login response\", function () {",
                  "    pm.expect(rawToken, \"Expected an access token in the response body\").to.be.a(\"string\").and.not.empty;",
                  "});",
                  "",
                  "if (rawToken) {",
                  "    const trimmedToken = String(rawToken).trim();",
                  "    const hasBearerPrefix = /^Bearer\\s+/i.test(trimmedToken);",
                  "    const normalizedType = String(tokenType || 'Bearer').trim();",
                  "    const normalizedToken = hasBearerPrefix",
                  "        ? trimmedToken.replace(/^Bearer\\s+/i, '')",
                  "        : trimmedToken;",
                  "",
                  "    pm.collectionVariables.set(\"access_token\", normalizedToken);",
                  "    pm.collectionVariables.set(\"access_token_type\", hasBearerPrefix ? \"Bearer\" : normalizedType);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{login_username_effective}}\",\n  \"password\": \"{{login_password_effective}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{app_url}}/login",
              "host": [
                "{{app_url}}"
              ],
              "path": [
                "login"
              ]
            }
          },
          "response": []
        }
      ],
      "description": "Given I am a new potential customer\n\nWhen I sign in in the app\n\nThen I should ne able to log in as an application customer"
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create a new product",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function generateRandomString(length) {",
                  "    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';",
                  "    let result = '';",
                  "    for (let i = 0; i < length; i++) {",
                  "        result += chars.charAt(Math.floor(Math.random() * chars.length));",
                  "        }",
                  "        return result;",
                  "}",
                  "",
                  "const newProduct = \"product\" + generateRandomString(10);",
                  "",
                  "pm.collectionVariables.set(\"newProduct\", newProduct);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{access_token_type}} {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"{{newProduct}}\",\n    \"price\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{app_url}}/product",
              "host": [
                "{{app_url}}"
              ],
              "path": [
                "product"
              ]
            }
          },
          "response": []
        }
      ]
    },
